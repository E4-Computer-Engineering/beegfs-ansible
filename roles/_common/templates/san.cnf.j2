[ req ]
default_bits       = 2048
distinguished_name = req_distinguished_name
req_extensions     = req_ext
x509_extensions    = v3_ca # The extensions to add to the self signed cert
prompt             = no

[ req_distinguished_name ]
C                      = IT
ST                     = EmiliaRomagna
L                      = Scandiano
O                      = E4company
OU                     = TechFactory
commonName             = {{ _common_sys_mgmtd_host }}

[ req_ext ]
subjectAltName = @alt_names

[ v3_ca ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1   = localhost
DNS.2   = {{ _common_sys_mgmtd_host }}
IP.1    = 127.0.0.1
{% set __mgmtd_hostvars = hostvars[_common_sys_mgmtd_host] | default({}) %}
{% set __mgmtd_default_ipv4 = __mgmtd_hostvars.ansible_default_ipv4 | default({}) %}
{% set __mgmtd_ips = [__mgmtd_default_ipv4.address | default(''), __mgmtd_hostvars.ansible_host | default('')] | select | unique | list %}
{% for __ip in __mgmtd_ips %}
IP.{{ loop.index + 1 }}    = {{ __ip }}
{% endfor %}
